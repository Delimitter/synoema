-- SPDX-License-Identifier: MIT-0

Tree a = Leaf a | Node (Tree a) a (Tree a)

inorder (Leaf x) = [x]
inorder (Node left val right) = inorder left ++ [val] ++ inorder right

join_sp xs =
  ? xs == [] -> ""
  : ? length xs == 1 -> show (head xs)
  : show (head xs) ++ " " ++ join_sp (tail xs)

tree = Node (Node (Leaf 1) 3 (Leaf 4)) 5 (Node (Leaf 6) 7 (Leaf 9))

main = join_sp (inorder tree)
