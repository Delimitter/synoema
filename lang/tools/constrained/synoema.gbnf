# Synoema Grammar in GBNF Format
# Compatible with: llama.cpp, XGrammar (SGLang/vLLM/TensorRT-LLM), Outlines
#
# This grammar guarantees 100% syntactic correctness of LLM-generated Synoema code.
# All operators are single BPE tokens in cl100k_base / Llama tokenizers.
#
# Usage with SGLang:
#   curl http://localhost:30000/generate \
#     -H "Content-Type: application/json" \
#     -d '{"text": "Write a factorial function in Synoema:", "extra_body": {"ebnf": "<grammar>"}}'
#
# Usage with llama.cpp:
#   ./main -m model.gguf --grammar-file synoema.gbnf -p "Write quicksort in Synoema:"

# ── Top Level ────────────────────────────────────────────

root ::= program

program ::= (top-item newline)* top-item newline?

top-item ::= import-decl | module-decl | use-decl | decl

# ── Module System ────────────────────────────────────────

import-decl ::= "import" ws string-lit

module-decl ::= "mod" ws upper-id newline (ws func-def newline)+

use-decl ::= "use" ws upper-id ws "(" ws use-names ws ")"
use-names ::= "*" | lower-id (ws lower-id)*

decl ::= func-def | type-sig | type-def | type-alias | test-decl

# ── Test Declarations ────────────────────────────────────

test-decl ::= "test" ws string-lit ws "=" ws expr

# ── Type Aliases ────────────────────────────────────────

type-alias ::= "type" ws upper-id (ws lower-id)* ws "=" ws type

# ── Function Definition ──────────────────────────────────

func-def ::= lower-id ws (pattern ws)* "=" ws expr

type-sig ::= lower-id ws ":" ws type

# ── Type Definitions (ADT) ───────────────────────────────

type-def ::= upper-id (ws lower-id)* ws "=" ws variants (ws "derive" ws "(" ws upper-id (ws "," ws upper-id)* ws ")")?

variants ::= variant (ws "|" ws variant)*

variant ::= upper-id (ws type-atom)*

# ── Expressions (precedence climbing) ────────────────────

expr ::= cond-expr | prop-expr | pipe-expr

cond-expr ::= "?" ws expr ws "->" ws expr ws ":" ws expr

prop-expr ::= "prop" ws lower-id (ws lower-id)* ws "->" ws expr

pipe-expr ::= when-expr (ws "|>" ws when-expr)*

when-expr ::= or-expr (ws "when" ws or-expr)*

or-expr ::= and-expr (ws "||" ws and-expr)*

and-expr ::= cmp-expr (ws "&&" ws cmp-expr)*

cmp-expr ::= concat-expr (ws cmp-op ws concat-expr)?

cmp-op ::= "==" | "!=" | "<=" | ">=" | "<" | ">"

concat-expr ::= add-expr (ws "++" ws add-expr)*

add-expr ::= mul-expr (ws ("+" | "-") ws mul-expr)*

mul-expr ::= compose-expr (ws ("*" | "/" | "%") ws compose-expr)*

compose-expr ::= unary-expr (ws ">>" ws unary-expr)*

unary-expr ::= "-" ws access-expr | access-expr

access-expr ::= app-expr ("." lower-id)*

app-expr ::= atom (ws atom)*

# ── Atoms ────────────────────────────────────────────────

atom ::= lower-id
       | upper-id
       | int-lit
       | float-lit
       | string-lit
       | char-lit
       | bool-lit
       | tuple-expr
       | "(" ws expr ws ")"
       | list-expr
       | lambda-expr
       | record-expr

tuple-expr ::= "(" ws expr ws "," ws expr ws ")"

record-expr ::= "{" ws "}"
              | "{" ws record-field (ws "," ws record-field)* ws "}"
              | "{" ws "..." ws expr (ws "," ws record-field)* ws "}"

record-field ::= lower-id ws "=" ws expr | lower-id

lambda-expr ::= "\\" ws (pattern ws)+ "->" ws expr

list-expr ::= "[" ws "]"
            | "[" ws expr (ws expr)* ws "]"
            | "[" ws expr ws "|" ws generators ws "]"
            | "[" ws expr ws ".." ws expr ws "]"

generators ::= generator (ws "," ws generator)*

generator ::= lower-id ws "<-" ws expr
            | expr

# ── Patterns ─────────────────────────────────────────────

pattern ::= "_"
          | lower-id
          | int-lit
          | string-lit
          | bool-lit
          | upper-id (ws pattern)*
          | "(" ws pattern ws "," ws pattern ws ")"
          | "(" ws pattern ws ":" ws pattern ws ")"
          | "(" ws pattern ws ")"
          | "[" ws "]"
          | record-pattern

record-pattern ::= "{" ws record-pat-field (ws "," ws record-pat-field)* ws "}"
record-pat-field ::= lower-id ws "=" ws pattern | lower-id

# ── Types ────────────────────────────────────────────────

type ::= type-atom (ws "->" ws type)?

type-atom ::= upper-id
            | lower-id
            | "(" ws type ws ")"
            | "[" ws type ws "]"

# ── Literals ─────────────────────────────────────────────

int-lit ::= "0" | [1-9] [0-9]*

float-lit ::= int-lit "." [0-9]+

string-lit ::= "\"" string-content* "\""

string-content ::= string-char+ | interpolation

interpolation ::= "${" expr "}"

string-char ::= [^"\\\n$] | "\\" [nrt\\"0$] | "$" [^{]

char-lit ::= "'" ([^'\\\n] | "\\" [nrt\\'0]) "'"

bool-lit ::= "true" | "false"

# ── Identifiers ──────────────────────────────────────────

lower-id ::= [a-z] [a-zA-Z0-9_]*

upper-id ::= [A-Z] [a-zA-Z0-9]*

# ── Keywords (reserved) ─────────────────────────────────
# mod, use, import, trait, impl, type, true, false, lazy
# These are handled by the identifier rules above

# ── Whitespace & Structure ───────────────────────────────

ws ::= [ \t]*

newline ::= "\n" [ \t]*

# ── Comments (optional - LLM may or may not generate) ────

comment ::= "--" [^\n]*
doc-comment ::= "---" " "? [^\n]*
